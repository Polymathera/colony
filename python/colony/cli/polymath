#!/bin/bash


# Ensure python version higher than or equal to 3.12 is installed on the system and
# use it to run the polymath.py file in the same directory as this file (even if
# the current working directory is different) and pass all command-line arguments to it.

# Check if Python 3.12 or higher is installed
python_version=$(python3 -c "import sys; print(f'{sys.version_info.major}.{sys.version_info.minor}')" 2>/dev/null)

if [ $? -ne 0 ] || [ $(echo "$python_version" | awk -F. '{if ($1 >= 3 && $2 >= 12) print 1; else print 0;}') -eq 0 ]; then
    echo "Error: Python 3.12 or higher is required."
    exit 1
fi

# Get the directory of this script
script_dir=$(dirname "$0")

# Run polymath.py with all command-line arguments
exec python3 "$script_dir/polymath.py" "$@"
