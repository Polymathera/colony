"""Mission ``${name}`` — authored via L1-E ``bootstrap_mission``.

Lives at ``.colony/missions/${name}.py``. L1-A's ``discover_missions``
walks ``.colony/missions/*.py``, calls the ``mission_entry()`` factory
exposed by each file, validates the returned dict against
:class:`polymathera.colony.agents.configs.MissionSpec`, and keys the
result by the file stem (so ``${name}`` becomes the mission key the
``SessionAgent``'s planner sees in ``available_missions``).

Fill in the placeholder fields and re-discover. The factory must
return every key declared on ``MissionSpec``; ``extra='forbid'`` is
on, so unknown keys fail validation rather than silently passing.
"""

from __future__ import annotations

from typing import Any


def mission_entry() -> dict[str, Any]:
    return {
        "label": "${name} mission",
        "description": "TODO: one-line description of what this mission does.",
        "coordinator_v1": "TODO.module.path.CoordinatorClass",
        "coordinator_v2": "TODO.module.path.CoordinatorClass",
        "worker": "TODO.module.path.WorkerClass",
        "coordinator_capabilities": [],
        "worker_capabilities": [],
        "caller_parameters": [],
        "self_concept": {
            "description": "TODO: how the coordinator describes itself to its planner.",
            "goals": [],
            "constraints": [],
        },
    }
