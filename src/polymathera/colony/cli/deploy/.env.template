# Colony deploy-time secrets.
#
# Copy this file to .env and fill in the values you need:
#
#   cp .env.template .env
#
# Then either ``source .env`` in your shell, or let
# ``colony-env up`` pick the keys up via env.py:load_dotenv — both
# paths work, and the two paths are union'd (a key set in the shell
# AND in .env reads from the shell first).
#
# docker-compose.yml resolves every ${VAR:-} placeholder from the
# operator's shell environment at ``docker compose up`` time, so any
# secret a service needs at runtime MUST be in your shell — either
# exported in your profile, or exported via ``source .env``. Empty
# defaults are silently propagated (the ``:-`` syntax), which means
# missing values surface later as opaque 401s from APIs / git
# clones; populate the ones you actually use.
#
# Operator config knobs (PDF extractor backend, image dir,
# vector-store URL, etc.) live in the operator YAML — see
# ``configs/example.yaml`` under ``knowledge``. Secrets here, knobs
# there.


# ---- LLM provider keys -----------------------------------------------------
# At least one must be set for the agent system to plan + dispatch.

ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
MISTRAL_API_KEY=
LLAMA_CLOUD_API_KEY=


# ---- Git remote credentials ------------------------------------------------
# GitHub HTTPS auth uses the GitHub App installation flow (see the
# trio below). The agent process mints a short-lived installation
# token at startup + writes it to a file the Dockerfile credential
# helper reads; ``colony/distributed/git_credentials.py`` owns the
# refresh loop. No PAT involved. GitLab still uses its own token
# until the GitLab integration follows the same shape.

GITLAB_TOKEN=

# Alternative to a PAT: GitHub App auth (deploy-level). The
# per-tenant installation id lives on the ``tenants`` Postgres row
# (set by each tenant via the Tenant GitHub Installation UI), not in
# env. ``GitHubAuthConfig`` reads the two below; the runtime mints
# a short-lived installation token by combining them with the
# per-session installation id from agent metadata.
#
# IMPORTANT — PEM formatting. docker-compose's ``environment:`` list
# truncates env-var values at the first real newline, so the PEM
# MUST be on a single line with literal ``\n`` escapes (NOT real
# newlines) between header / body lines / footer. The
# ``GitHubAuthConfig._normalize_pem`` validator converts the
# escapes back to real newlines before handing the key to pyjwt.
# Convert a downloaded ``.pem`` with:
#
#   awk 'BEGIN{ORS="\\n"} {print}' /path/to/colony-app.pem
#
# (Wrap the output in double quotes when pasting into .env.) Then
# the line below should look like:
#
#   GITHUB_PRIVATE_KEY_PEM="-----BEGIN RSA PRIVATE KEY-----\nMIIEp...\n...\n-----END RSA PRIVATE KEY-----\n"
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY_PEM=

# OAuth client credentials for the same GitHub App's user-to-server
# flow (the "Connect GitHub" button on a user's profile). Needed
# only when users authenticate their GitHub identity through Colony
# — when unset, the connect flow is disabled but the rest of the
# App auth keeps working.
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=

# P9 webhook receiver — HMAC-SHA256 secret the
# ``POST /api/v1/github/webhook`` route verifies inbound payloads
# against. Operator sets the matching value in the GitHub App's
# "Webhook secret" field. Required only when at least one colony
# sets ``mode: webhook`` in its ``.colony/github_inbound.yaml`` —
# leave empty for the poll-only (P8a) path.
GITHUB_WEBHOOK_SECRET=

# Local-dev only: smee.io channel URL for forwarding GitHub
# webhooks to ``localhost``. When set, ``colony-env up`` starts a
# ``smee-forwarder`` sidecar (Node + ``npx smee-client@latest``)
# that subscribes to the channel and relays each delivery to
# ``http://dashboard:8080/api/v1/github/webhook`` inside the
# compose network. ``colony-env down`` tears it down with the rest
# of the stack. Production deployments leave this empty — GitHub
# posts straight to the dashboard's public URL.
#
# How to get a channel URL:
#   1. Visit https://smee.io/new in a browser — the page issues a
#      fresh channel and redirects to https://smee.io/<channel-id>.
#   2. Paste that URL both here AND into the GitHub App's
#      "Webhook URL" field (so GitHub posts to the channel; the
#      sidecar relays from the channel into your dashboard).
POLYMATHERA_SMEE_FORWARDING_URL=

# Dev-mode license seeding. Comma-separated list of
# ``<github_installation_id>:<plan>`` pairs. On every dashboard
# startup (and on every signup walker pass that lands a new tenant),
# each entry is upserted into the ``licenses`` table with
# ``source='env_bootstrap'``. Tenants NOT in this list and not seeded
# by Marketplace / Stripe / admin source fall through to plan='free'
# on first license read.
#
# The seeder respects the source-precedence ladder:
#   admin > license_jwt > marketplace > stripe > env_bootstrap > default
# so an env_bootstrap write never overwrites a higher-priority source.
#
# Plans: free | team | business | enterprise | dev (no caps, all features).
# When the ``:<plan>`` suffix is omitted the entry defaults to ``dev``.
#
# Example:
# COLONY_DEV_LICENSED_INSTALLATIONS=12345678:enterprise,87654321
COLONY_DEV_LICENSED_INSTALLATIONS=


# ---- At-rest secrets encryption -------------------------------------------
# Symmetric Fernet (AES-128-CBC + HMAC-SHA256) key for encrypting
# operator-supplied bot tokens at rest in postgres
# (``tenants.bot_token_encrypted`` — GitLab Group Access Tokens /
# Bitbucket workspace API tokens; GitHub installation tokens are
# auto-minted from the App private key and never stored).
#
# Generate one per deployment:
#   python -c "from cryptography.fernet import Fernet; \
#              print(Fernet.generate_key().decode())"
#
# REQUIRED when any tenant uses a non-GitHub VCS provider (today this
# means GitLab — PR 7+). GitHub-only deployments can leave it empty;
# code paths that need it raise a clean SecretsConfigError pointing
# back here.
#
# Rotation: generate a new key, decrypt every row with the old, encrypt
# with the new, then replace the env value. One-key-at-a-time only.
COLONY_SECRETS_FERNET_KEY=


# ---- GitLab OAuth Application ---------------------------------------------
# OAuth Application credentials for the GitLab provider. Register an
# OAuth application at:
#   - gitlab.com:  https://gitlab.com/-/user_settings/applications
#   - Self-hosted: https://<your-gitlab-host>/-/user_settings/applications
# Scopes required: ``read_api`` (the walker calls ``GET /user`` +
# ``GET /groups`` + ``GET /projects`` + ``GET /repository/tree``).
# Redirect URI: ``<your-colony-public-url>/api/v1/auth/gitlab/callback``
# (matches the generic ``/auth/{provider}/callback`` pattern in
# ``routers/auth.py``).
#
# Leaving these empty leaves the GitLab provider unregistered;
# ``GET /api/v1/auth/gitlab/sign-in`` then returns 404.
GITLAB_OAUTH_CLIENT_ID=
GITLAB_OAUTH_CLIENT_SECRET=
# Override only for self-hosted GitLab (CE/EE). Defaults to gitlab.com.
# Example: GITLAB_BASE_URL=https://gitlab.acme.internal
GITLAB_BASE_URL=


# ---- Web search (TavilyAPI, consumed by WebSearchCapability) --------------

TAVILY_API_KEY=


# ---- Slack notifier --------------------------------------------------------
# Consumed by the Slack-relay capability when wired into a session.
# Leave empty when no Slack integration is configured.

SLACK_APP_TOKEN=
SLACK_BOT_TOKEN=


# ---- Postgres (cluster-internal) -------------------------------------------
# Used by the ``postgres`` service in docker-compose for the dashboard
# and session-state backend. Default is ``colony_dev`` (fine for local
# development; override for shared deployments).

COLONY_PG_PASSWORD=colony_dev


# ---- Operational toggles ---------------------------------------------------
# ``COLONY_AUTO_DEPLOY=true`` makes ``colony-env up`` also call
# ``polymath deploy`` after the cluster is healthy (the common dev
# path). Set to ``false`` to bring up just the container stack and
# defer the application-level deploy.

COLONY_AUTO_DEPLOY=true
