# Colony deploy-time secrets.
#
# Copy this file to .env and fill in the values you need:
#
#   cp .env.template .env
#
# Then either ``source .env`` in your shell (required for ``git push``
# against private remotes that rely on $GITHUB_TOKEN), or let
# ``colony-env up`` pick the keys up via env.py:load_dotenv â€” both
# paths work, and the two paths are union'd (a key set in the shell
# AND in .env reads from the shell first).
#
# docker-compose.yml resolves every ${VAR:-} placeholder from the
# operator's shell environment at ``docker compose up`` time, so any
# secret a service needs at runtime MUST be in your shell â€” either
# exported in your profile, or exported via ``source .env``. Empty
# defaults are silently propagated (the ``:-`` syntax), which means
# missing values surface later as opaque 401s from APIs / git
# clones; populate the ones you actually use.
#
# Operator config knobs (PDF extractor backend, image dir,
# vector-store URL, etc.) live in the operator YAML â€” see
# ``configs/example.yaml`` under ``knowledge``. Secrets here, knobs
# there.


# ---- LLM provider keys -----------------------------------------------------
# At least one must be set for the agent system to plan + dispatch.

ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
MISTRAL_API_KEY=
LLAMA_CLOUD_API_KEY=


# ---- Git remote credentials ------------------------------------------------
# Used by:
#   - the Dockerfile.base credential helper for HTTPS git clone / push
#     (the design monorepo clone path);
#   - polymath shell ``git push`` from the operator workstation when
#     pushing through the same credentials.
# At least one of GITHUB_TOKEN / the GITHUB_APP_* trio must be set if
# you point Colony at a private GitHub design monorepo. GitLab uses
# its own token.

GITHUB_TOKEN=
GITLAB_TOKEN=

# Alternative to a PAT: GitHub App auth. When all three are set,
# ``GitHubAuthConfig`` mints a short-lived installation token at
# runtime â€” recommended for production (rotation + scoping).
GITHUB_APP_ID=
GITHUB_INSTALLATION_ID=
GITHUB_PRIVATE_KEY_PEM=


# ---- Web search (TavilyAPI, consumed by WebSearchCapability) --------------

TAVILY_API_KEY=


# ---- Slack notifier --------------------------------------------------------
# Consumed by the Slack-relay capability when wired into a session.
# Leave empty when no Slack integration is configured.

SLACK_APP_TOKEN=
SLACK_BOT_TOKEN=


# ---- Postgres (cluster-internal) -------------------------------------------
# Used by the ``postgres`` service in docker-compose for the dashboard
# and session-state backend. Default is ``colony_dev`` (fine for local
# development; override for shared deployments).

COLONY_PG_PASSWORD=colony_dev


# ---- Operational toggles ---------------------------------------------------
# ``COLONY_AUTO_DEPLOY=true`` makes ``colony-env up`` also call
# ``polymath deploy`` after the cluster is healthy (the common dev
# path). Set to ``false`` to bring up just the container stack and
# defer the application-level deploy.

COLONY_AUTO_DEPLOY=true
